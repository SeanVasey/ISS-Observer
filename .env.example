# ISS Observer — Environment Variables
#
# Copy this file to .env or .env.local and fill in values as needed.
# None of these are required for local development.
#
# Currently, runtime configuration is handled via public/config.js
# rather than build-time environment variables. This file documents
# the pattern for future use.

# Nominatim geocoder contact email (recommended for production)
# Set this in public/config.js → window.VASEY_CONFIG.nominatimEmail
# NOMINATIM_EMAIL=your-email@example.com
